{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommandEngine module manifest",
  "type": "object",
  "required": ["module"],
  "additionalProperties": false,
  "definitions": {
    "command": {
      "type": "object",
      "properties": {

        "intent": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Имя интента внутри модуля."
        },

        "examples": {
          "type": "array",
          "minItems": 1,
          "items": { 
            "type": "string" 
          },
          "description": "Обучающие фразы. Сущности размечаются [значение](имя)."
        },

        "entities": { 
          "$ref": "#/definitions/entities" 
        },

        "slots": { 
          "$ref": "#/definitions/slots" 
        },

        "form": { 
          "$ref": "#/definitions/form" 
        },

        "response": { 
          "$ref": "#/definitions/response" 
        },

        "handler": { 
          "$ref": "#/definitions/handler" 
        },

        "stories": { 
          "type": "array", 
          "items": { 
            "type": "object" 
          } 
        }
      }
    },

    "entities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "lookup": { 
            "type": "array", 
            "items": { 
              "type": "string" 
            } 
          },
          "synonyms": {
            "type": "object",
            "additionalProperties": { 
              "type": "array", 
              "items": { 
                "type": "string" 
              } 
            }
          }
        }
      }
    },

    "slots": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from"
        ],
        "properties": {
          "type": { 
            "type": "string", 
            "enum": [
              "text", "bool", "float", "categorical", "list", "any"
            ] 
          },
          "from": { 
            "type": "string", 
            "enum": [
              "entity", "text", "intent"
            ] 
          },
          "entity": { 
            "type": "string" 
          },
          "values": { 
            "type": "array", 
            "items": { 
              "type": "string" 
            } 
          }
        }
      }
    },

    "form": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required", "ask"
      ],
      "properties": {
        "required": { 
          "type": "array", 
          "minItems": 1, 
          "items": { 
            "type": "string" 
          } 
        },
        "ask": { 
          "type": "object", 
          "additionalProperties": { 
            "type": "string" 
          } 
        },
        "validate": { 
          "type": "object", 
          "additionalProperties": { 
            "type": "string" 
          } 
        }
      }
    },

    "response": {
      "oneOf": [
        { 
          "type": "string" 
        },
        { 
          "type": "array", 
          "minItems": 1, 
          "items": { 
            "type": "string" 
          } 
        }
      ],
      "description": "Готовый текст для статической команды."
    },

    "handler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { 
          "type": "string", 
          "enum": [
            "function", "http"
          ] 
        },
        "name": { 
          "type": "string", 
          "description": "Имя функции в handler.py." 
        },
        "url": { 
          "type": "string" 
        }
      }
    }
  },

  "properties": {
    "module": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Уникальное имя модуля = имя папки. Становится префиксом интента."
    },
    "version": { 
      "type": "string" 
    },

    "commands": {
      "type": "array",
      "minItems": 1,
      "items": { 
        "$ref": "#/definitions/command" 
      }
    },

    "intent": { 
      "$ref": "#/definitions/command/properties/intent" 
    },
    "examples": { 
      "$ref": "#/definitions/command/properties/examples" 
    },
    "entities": { 
      "$ref": "#/definitions/entities" 
    },
    "slots": { 
      "$ref": "#/definitions/slots" 
    },
    "form": { 
      "$ref": "#/definitions/form" 
    },
    "response": { 
      "$ref": "#/definitions/response" 
    },
    "handler": { 
      "$ref": "#/definitions/handler" 
    },
    "stories": { 
      "type": "array", 
      "items": { 
        "type": "object" 
      } 
    }
  }
}
