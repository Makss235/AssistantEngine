{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommandEngine module manifest",
  "type": "object",
  "required": ["module", "intent", "examples"],
  "additionalProperties": false,
  "properties": {
    "module": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Уникальное имя модуля = имя папки. Становится префиксом интента."
    },
    "version": { "type": "string" },
    "intent": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Имя интента ВНУТРИ модуля. Финально склеивается в module_intent."
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Обучающие фразы. Сущности размечаются [значение](имя)."
    },
    "entities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "lookup": { "type": "array", "items": { "type": "string" } },
          "synonyms": {
            "type": "object",
            "additionalProperties": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "slots": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from"],
        "properties": {
          "type": { "type": "string", "enum": ["text", "bool", "float", "categorical", "list", "any"] },
          "from": { "type": "string", "enum": ["entity", "text", "intent"] },
          "entity": { "type": "string" },
          "values": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "form": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "ask"],
      "properties": {
        "required": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "ask": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "validate": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "response": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "minItems": 1, "items": { "type": "string" } }
      ],
      "description": "Готовый текст для СТАТИЧЕСКОЙ команды (строка или массив вариантов)."
    },
    "handler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["function", "http"] },
        "name": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "stories": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
