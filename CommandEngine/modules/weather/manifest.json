{
  "module": "weather",
  "intent": "ask",
  "examples": [
    "какая погода",
    "что там с погодой",
    "расскажи прогноз",
    "будет ли дождь",
    "погода в [москве](city)",
    "прогноз для [питера](city)",
    "какая погода в [казани](city)",
    "будет дождь в [новосибирске](city)"
  ],

  "entities": {
    "city": {
      "lookup": [
        "москва", "санкт-петербург", "казань", "новосибирск", "екатеринбург"
      ],
      "synonyms": { 
        "санкт-петербург": [
          "питер", "спб"
        ] 
      }
    }
  },

  "slots": {
    "city": { 
      "type": "text", 
      "from": "entity" 
    }
  },

  "handler": { 
    "type": "function", 
    "name": "weather.run" 
  }
}