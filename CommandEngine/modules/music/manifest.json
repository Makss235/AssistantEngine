{
  "module": "music",
  "entities": {
    "artist": { 
      "lookup": [
        "металлику", "кино", "нирвану", "queen", "рамштайн"
      ] 
    }
  },
  "commands": [
    {
      "intent": "play",
      "examples": [
        "включи музыку",
        "поставь музыку",
        "врубай музыку",
        "включи [металлику](artist)",
        "поставь [кино](artist)",
        "включи [queen](artist)"
      ],
      "handler": { 
        "type": "function", 
        "name": "run_play" 
      }
    },
    {
      "intent": "pause",
      "examples": [
        "поставь на паузу",
        "пауза",
        "останови музыку",
        "приостанови",
        "поставь музыку на паузу"
      ],
      "handler": { 
        "type": "function", 
        "name": "run_pause" 
      }
    },
    {
      "intent": "next",
      "examples": [
        "следующий трек",
        "следующая песня",
        "переключи дальше",
        "дальше",
        "next"
      ],
      "response": [
        "Включаю следующий трек.", 
        "Переключаю дальше."
      ]
    }
  ]
}
